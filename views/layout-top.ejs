<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' : '' %>Bridge AI</title>
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof metaRefresh !== 'undefined' && metaRefresh) { %>
  <noscript><meta http-equiv="refresh" content="<%= metaRefresh %>"></noscript>
  <% } %>
</head>
<body>
  <div class="container">
    <div class="site-header">
      <table class="header-table" width="100%">
        <tr>
          <td><a href="/chats" class="site-title">Bridge AI</a></td>
          <td align="right">
            <% if (typeof user !== 'undefined' && user) { %>
              <a href="/chats">Chats</a> |
              <a href="/usage">Usage</a> |
              <a href="/billing">Plan</a> |
              <form method="POST" action="/auth/logout" style="display:inline">
                <button type="submit" class="link-btn">Logout</button>
              </form>
            <% } else { %>
              <a href="/auth/login">Login</a> |
              <a href="/auth/register">Register</a>
            <% } %>
          </td>
        </tr>
      </table>
    </div>

    <% if (typeof flash !== 'undefined' && flash) { %>
      <div class="flash flash-<%= flash.type || 'info' %>">
        <%= flash.message %>
      </div>
    <% } %>

    <div class="main">
